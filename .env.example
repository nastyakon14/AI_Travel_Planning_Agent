# =============================================================================
# AI Travel Planning Agent — Environment Variables
# =============================================================================
# Скопируйте этот файл в .env и заполните значения:
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# LLM (обязательно)
# -----------------------------------------------------------------------------
# API-ключ для OpenAI-совместимого шлюза (LiteLLM / AgentPlatform)
AGENTPLATFORM_API_KEY=your_api_key_here

# Базовый URL API LLM (OpenAI-compatible endpoint)
AGENTPLATFORM_API_BASE=https://litellm.tokengate.ru/v1

# Модели для извлечения запроса (fast/strong cascade)
TRIP_EXTRACTION_FAST_MODEL=gpt-4o-mini
TRIP_EXTRACTION_STRONG_MODEL=gpt-4o

# Модель для подбора достопримечательностей (по умолчанию = FAST)
# TRIP_ATTRACTIONS_MODEL=gpt-4o-mini

# Модель для генерации маршрута (по умолчанию = FAST)
# TRIP_ITINERARY_MODEL=gpt-4o-mini

# Цены токенов для оценки стоимости (USD за 1000 токенов)
# LLM_DEFAULT_INPUT_USD_PER_1K=0.00015
# LLM_DEFAULT_OUTPUT_USD_PER_1K=0.0006

# -----------------------------------------------------------------------------
# Travelpayouts / Aviasales / Hotellook (обязательно для поиска)
# -----------------------------------------------------------------------------
TRAVELPAYOUTS_API_TOKEN=your_travelpayouts_token_here

# -----------------------------------------------------------------------------
# Prometheus метрики (опционально)
# -----------------------------------------------------------------------------
# Включить экспорт метрик (1/true/yes)
# PROMETHEUS_ENABLE=1
# Порт для /metrics endpoint (внутри контейнера)
# PROMETHEUS_METRICS_PORT=9090

# -----------------------------------------------------------------------------
# Langfuse трассировка (опционально)
# -----------------------------------------------------------------------------
# LANGFUSE_PUBLIC_KEY=pk_lf_...
# LANGFUSE_SECRET_KEY=sk_lf_...
# LANGFUSE_HOST=https://cloud.langfuse.com

# -----------------------------------------------------------------------------
# Порты сервисов (Docker Compose)
# -----------------------------------------------------------------------------
UI_PORT=8501
METRICS_PORT=9090
PROMETHEUS_UI_PORT=9091
GRAFANA_PORT=3000

# -----------------------------------------------------------------------------
# Прочее
# -----------------------------------------------------------------------------
# Максимальное кол-во результатов поиска (1-10)
# MAX_RESULTS_DEFAULT=5

# Максимальное кол-во retry-попыток guardrail
# TRAVEL_GUARDRAIL_MAX_RETRIES=3

# Первый день недели для дат (0=понедельник)
# WEEK_START=1
